\pard\sa200\sl276\slmult1\f0\fs20\b Backend Authentication Logic:\b0\par
\pard\sa200\sl276\slmult1\f0\fs20\par
\pard\sa200\sl276\slmult1\f0\fs20```javascript\par
\pard\sa200\sl276\slmult1\f0\fs20static async login(req, res) \{\par
\pard\sa200\sl276\slmult1\f0\fs20  try \{\par
\pard\sa200\sl276\slmult1\f0\fs20    const \{ email, password \} = req.body;\par
\pard\sa200\sl276\slmult1\f0\fs20    \par
\pard\sa200\sl276\slmult1\f0\fs20    // Find user in database\par
\pard\sa200\sl276\slmult1\f0\fs20    const user = await User.findByEmail(email);\par
\pard\sa200\sl276\slmult1\f0\fs20    if (!user) \{\par
\pard\sa200\sl276\slmult1\f0\fs20      return res.status(401).json(\{ message: 'Invalid credentials' \});\par
\pard\sa200\sl276\slmult1\f0\fs20    \}\par
\pard\sa200\sl276\slmult1\f0\fs20    \par
\pard\sa200\sl276\slmult1\f0\fs20    // Validate password\par
\pard\sa200\sl276\slmult1\f0\fs20    const isValidPassword = await User.validatePassword(password, user.password);\par
\pard\sa200\sl276\slmult1\f0\fs20    if (!isValidPassword) \{\par
\pard\sa200\sl276\slmult1\f0\fs20      return res.status(401).json(\{ message: 'Invalid credentials' \});\par
\pard\sa200\sl276\slmult1\f0\fs20    \}\par
\pard\sa200\sl276\slmult1\f0\fs20    \par
\pard\sa200\sl276\slmult1\f0\fs20    // Generate JWT token\par
\pard\sa200\sl276\slmult1\f0\fs20    const token = generateToken(\{ \par
\pard\sa200\sl276\slmult1\f0\fs20      userId: user.id, \par
\pard\sa200\sl276\slmult1\f0\fs20      email: user.email, \par
\pard\sa200\sl276\slmult1\f0\fs20      role: user.role \par
\pard\sa200\sl276\slmult1\f0\fs20    \});\par
\pard\sa200\sl276\slmult1\f0\fs20    \par
\pard\sa200\sl276\slmult1\f0\fs20    res.json(\{\par
\pard\sa200\sl276\slmult1\f0\fs20      message: 'Login successful',\par
\pard\sa200\sl276\slmult1\f0\fs20      token,\par
\pard\sa200\sl276\slmult1\f0\fs20      user: \{ id: user.id, name: user.name, email: user.email, role: user.role \}\par
\pard\sa200\sl276\slmult1\f0\fs20    \});\par
\pard\sa200\sl276\slmult1\f0\fs20  \} catch (error) \{\par
\pard\sa200\sl276\slmult1\f0\fs20    res.status(500).json(\{ message: 'Internal server error' \});\par
\pard\sa200\sl276\slmult1\f0\fs20  \}\par
\pard\sa200\sl276\slmult1\f0\fs20\}\par
\pard\sa200\sl276\slmult1\f0\fs20```\par
\pard\sa200\sl276\slmult1\f0\fs20\par
